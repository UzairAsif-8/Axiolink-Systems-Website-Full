{
  "name": "axiolink-systems-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run dev --prefix backend",
    "dev:all": "npx concurrently -n frontend,backend -c blue,green \"npm run dev\" \"npm run dev:backend\"",
    "setup:backend": "npm run db:setup --prefix backend",
    "seed": "npm run seed --prefix backend",
    "seed:blog": "npm run seed:blog-articles --prefix backend",
    "seed:hybrid-internships": "npm run seed:hybrid-internships --prefix backend",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start:server": "node server/index.js"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@react-three/fiber": "^8.18.0",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.294.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.20.1",
    "recharts": "^3.9.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0"
  }
}
