# Frontend (Vite) — copy this file to `.env` in the project root (same folder as package.json)

# Canonical site URL used for sitemap.xml and SEO metadata
VITE_SITE_URL=https://www.axiolinksystems.com

# --- API base URL ---
# Production builds use same-origin `/api` by default (Vercel rewrites to Render).
# That keeps auth cookies first-party so mobile login works.
#
# Local: leave unset to use the Vite proxy → http://localhost:4000
# Or point at a remote API while developing (cross-origin; may fail on mobile):
# VITE_API_URL=https://axiolink-systems-website-full.onrender.com
#
# Escape hatch if you must call Render directly from a production build:
# VITE_API_SAME_ORIGIN=false
# VITE_API_URL=https://axiolink-systems-website-full.onrender.com

# EmailJS credentials (Dashboard → Account → API Keys / Email Services / Email Templates)
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

# Template variables sent by the contact form:
# {{from_name}} {{from_email}} {{subject}} {{message}} {{time}}
