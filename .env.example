# Frontend (Vite) — copy this file to `.env` in the project root (same folder as package.json)

# EmailJS credentials (Dashboard → Account → API Keys / Email Services / Email Templates)
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

# Template variables sent by the contact form (do not change unless your template changes):
# {{from_name}} {{from_email}} {{subject}} {{message}} {{time}}

# Optional — override API base (defaults to Vite proxy /api → localhost:4000)
# VITE_API_URL=
