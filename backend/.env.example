# =============================================================================
# Axiolink Systems — Backend Environment Variables
# Copy this file to .env and fill in all values before running the server.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Set to false when using Neon PostgreSQL (required for production)
USE_DEMO_DATA=false

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get your connection string from https://console.neon.tech
DATABASE_URL=

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate strong random strings (min 32 characters) for production
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Super Admin (NOT stored in database) ─────────────────────────────────────
# Login credentials read from environment — works immediately after deploy
ADMIN_EMAIL=admin@axiolinksystems.com
ADMIN_NAME=Uzair Asif
# Generate with: node scripts/hash-password.js YourSecurePassword
# Wrap in single quotes — bcrypt hashes contain $ characters
ADMIN_PASSWORD_HASH=123456

# Comma-separated list of allowed frontend origins (CORS)
# Local dev example:
# CLIENT_URL=http://localhost:3005,http://localhost:5173
# Production example:
# CLIENT_URL=https://axiolinksystems.com,https://www.axiolinksystems.com
CLIENT_URL=http://localhost:3005,http://localhost:5173

# Auth cookies — use "lax" when the frontend same-origin-proxies /api (Vercel rewrite).
# This is required for reliable admin login on mobile. Use "none" only for true
# cross-origin frontend → API calls (often blocked on mobile Safari/Chrome).
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_SECURE=true

# ─── File Storage (Cloudinary) ──────────────────────────────────────────────────
# REQUIRED in production. Render's disk is ephemeral — local uploads are deleted
# on every redeploy, which makes CV / payment-slip links return "Route not found".
# Set UPLOAD_PROVIDER=cloudinary and fill CLOUDINARY_* from https://cloudinary.com
UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: public API origin for local uploads (defaults to RENDER_EXTERNAL_URL)
# PUBLIC_BASE_URL=https://axiolink-systems-website-full.onrender.com

